# GMGN API Keys (comma-separated for rotation)
# Get keys at https://gmgn.ai/ai
GMGN_API_KEYS=gmgn_xxxxx,gmgn_yyyyy

# Server
PORT=3000

# Polling interval in ms (how often to check wallets)
POLL_INTERVAL_MS=3000

# Paper trading defaults
DEFAULT_POSITION_SOL=1.0
STOP_LOSS_PERCENT=50
TAKE_PROFIT_PERCENT=500
