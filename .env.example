# Get free API key from https://helius.dev (free tier: 100K credits/day)
HELIUS_API_KEY=your_helius_api_key_here

# Server
PORT=3000

# Polling interval in ms (how often to check wallets for new txns)
POLL_INTERVAL_MS=5000

# Paper trading defaults
DEFAULT_POSITION_SOL=1.0
STOP_LOSS_PERCENT=50
TAKE_PROFIT_PERCENT=500
